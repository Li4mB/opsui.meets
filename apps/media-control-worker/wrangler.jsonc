{
  "name": "opsui-meets-media-control",
  "main": "src/index.ts",
  "compatibility_date": "2026-03-29",
  "workers_dev": true,
  "vars": {
    "CLOUDFLARE_REALTIME_MEETING_PREFIX": "opsui-meets"
  },
  "durable_objects": {
    "bindings": [
      {
        "name": "MEETING_STATE",
        "class_name": "MeetingState"
      }
    ]
  },
  "migrations": [
    {
      "tag": "v1",
      "new_sqlite_classes": ["MeetingState"]
    }
  ]
}
