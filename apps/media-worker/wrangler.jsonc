{
  "name": "opsui-meets-media",
  "main": "src/index.ts",
  "compatibility_date": "2026-03-26",
  "workers_dev": false,
  "routes": [
    {
      "pattern": "media.opsuimeets.com",
      "custom_domain": true
    }
  ],
  "services": [
    {
      "binding": "MEDIA_CONTROL_SERVICE",
      "service": "opsui-meets-media-control"
    }
  ]
}
