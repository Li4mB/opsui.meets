APP_ENV=development
APP_DATA_MODE=postgres
COOKIE_DOMAIN=.meets.opsui.app
ALLOW_MOCK_AUTH=false
DEFAULT_WORKSPACE_ID=workspace_local
MOCK_SESSION_SIGNING_SECRET=replace-me
MOCK_AUTH_DEFAULT_EMAIL=
AUTH_MEMBERSHIP_DIRECTORY_JSON={"users":[]}
AUTH_ENFORCE_MEMBERSHIP_DIRECTORY=true
OIDC_ISSUER_URL=
OIDC_CLIENT_ID=
OIDC_CLIENT_SECRET=
OIDC_REDIRECT_URI=
OIDC_SCOPE=openid profile email
OIDC_AUTHORIZATION_ENDPOINT=
OIDC_TOKEN_ENDPOINT=
OIDC_USERINFO_ENDPOINT=
OIDC_WORKSPACE_CLAIM=workspace_id
OIDC_EMAIL_DOMAIN_WORKSPACE_MAP={}
OIDC_ALLOWED_WORKSPACE_IDS=
OIDC_ROLE_CLAIM=role
OIDC_DEFAULT_ROLE=participant
DATABASE_URL=postgres://user:password@localhost:5432/opsui_meets
R2_MEDIA_BUCKET=opsui-meets-media
MEDIA_DOWNLOAD_BASE_URL=https://media.meets.opsui.app/downloads/
MEDIA_UPLOAD_BASE_URL=https://media.meets.opsui.app/uploads/
MEDIA_BACKEND_BASE_URL=
MEDIA_CONTROL_SHARED_SECRET=
CF_ACCOUNT_ID=replace-me
PREVIEW_SMOKE_PUBLIC_GATEWAY_URL=
PREVIEW_SMOKE_API_URL=
PREVIEW_SMOKE_AUTH_URL=
PREVIEW_SMOKE_DOCS_URL=
PREVIEW_SMOKE_PREVIEW_URL=
