{
  "name": "@opsui/meets",
  "private": true,
  "version": "0.1.0",
  "packageManager": "pnpm@10.0.0",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "corepack pnpm -r build",
    "dev:api": "corepack pnpm --filter @opsui/api-worker dev",
    "dev:auth": "corepack pnpm --filter @opsui/auth-worker dev",
    "dev:media-control": "corepack pnpm --filter @opsui/media-control-worker dev",
    "dev:realtime": "corepack pnpm --filter @opsui/realtime-worker dev",
    "dev:web": "corepack pnpm --filter @opsui/web dev",
    "dev:admin": "corepack pnpm --filter @opsui/admin dev",
    "dev:docs": "corepack pnpm --filter @opsui/docs dev",
    "dev:preview": "corepack pnpm --filter @opsui/preview dev",
    "db:migrate": "corepack pnpm --filter @opsui/db db:migrate",
    "db:status": "corepack pnpm --filter @opsui/db db:status",
    "export:readiness": "node scripts/export-readiness.mjs",
    "export:topology": "node scripts/export-topology.mjs",
    "lint": "corepack pnpm -r lint",
    "smoke:published-readiness": "node scripts/check-published-readiness-assets.mjs",
    "smoke:production": "node scripts/smoke-production.mjs",
    "smoke:preview": "node scripts/smoke-preview.mjs",
    "smoke:production:meetings": "node scripts/smoke-production-meetings.mjs",
    "smoke:production:media": "node scripts/smoke-production-media-recovery.mjs",
    "smoke:readiness": "node scripts/check-readiness-artifacts.mjs",
    "smoke:manifest": "node scripts/check-topology-manifest.mjs",
    "smoke:published-assets": "node scripts/check-published-topology-assets.mjs",
    "smoke:topology": "node scripts/check-topology.mjs",
    "test:e2e": "playwright test",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:install": "playwright install chromium",
    "typecheck": "corepack pnpm -r typecheck",
    "verify": "corepack pnpm smoke:manifest && corepack pnpm smoke:topology && corepack pnpm smoke:readiness && corepack pnpm typecheck && corepack pnpm build && corepack pnpm smoke:published-assets && corepack pnpm smoke:published-readiness"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "latest",
    "@playwright/test": "^1.58.2",
    "typescript": "latest",
    "wrangler": "latest"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "sharp",
      "workerd"
    ]
  }
}
