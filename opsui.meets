      "binding": "MEDIA_BUCKET",
      "bucket_name": "opsui-meets-media"
    }
  ],
  "hyperdrive": [
    {
      "binding": "DB",
      "id": "REPLACE_WITH_HYPERDRIVE_ID"
    }
  ]
}
